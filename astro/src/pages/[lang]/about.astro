---
import Layout from "~/layouts/Base.astro";
import Subnav from "~/components/Subnav.astro";
import ResponsiveImage from "~/components/ResponsiveImage.tsx";
import TwitterIcon from "../../../../app/icons/Twitter";
import GithubIcon from "../../../../app/icons/Github";
import InstagramIcon from "../../../../app/icons/Instagram";
import YoutubeIcon from "../../../../app/icons/Youtube";
import type { Image } from "~/types/Image";
import { AboutText, HomepageText } from "~/locales";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import { LOCALES } from "~/lib/i18n/getLang";
import {
  generatePersonStructuredData,
  serializeStructuredData,
} from "~/lib/seo/structuredData";

export const prerender = false;

const { lang } = Astro.params;
if (!lang || !(LOCALES as readonly string[]).includes(lang)) {
  return new Response(null, { status: 404, statusText: "No such language" });
}

const supabase = Astro.locals.supabase;
const env = Astro.locals.runtime.env;
const baseUrl = env.BASE_URL;
const imgPrefix = env.IMG_PREFIX;

const content = AboutText(lang);
const label = getLanguageLabel(HomepageText, lang);

const { data: profileImage } = await supabase
  .from("image")
  .select(`alt, storage_key, width, height, caption`)
  .eq("storage_key", "ba07adad-3f02-409b-ad39-2814b6f2ede3")
  .single();

const availableLangs = ["zh", "en", "jp"];

const personJsonLd = generatePersonStructuredData({
  name: "李大毛",
  description: label.about_description,
  image: {
    url: `${imgPrefix}/cdn-cgi/image/format=jpeg,width=800/ba07adad-3f02-409b-ad39-2814b6f2ede3`,
    width: 800,
    height: 800,
  },
  url: `${baseUrl}/${lang}/about`,
  sameAs: [
    "https://x.com/darmau8964",
    "https://github.com/Darmau",
    "https://www.instagram.com/ridamoe",
    "https://www.youtube.com/@darmau",
  ],
});

const ogImage = `${imgPrefix}/cdn-cgi/image/format=jpeg,width=960/ba07adad-3f02-409b-ad39-2814b6f2ede3`;
---

<Layout
  lang={lang}
  title={label.about_title}
  description={label.about_description}
  ogTitle={label.about_title}
  ogDescription={label.about_description}
  ogImage={ogImage}
  ogType="website"
  pathWithoutLang="about"
  availableLangs={availableLangs}
  baseUrl={baseUrl}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeStructuredData(personJsonLd)}
    slot="head"
  />

  <Subnav lang={lang} active="about" />
  <div class="w-full max-w-6xl mx-auto p-4 md:py-8 my-8 lg:my-16 grid grid-cols-1 gap-y-16 lg:grid-cols-2 lg:grid-rows-[auto_1fr] lg:gap-y-12">
    <div class="lg:pl-20">
      {
        profileImage && (
          <ResponsiveImage
            client:visible
            image={profileImage as Image}
            width={560}
            classList="aspect-square rotate-3 rounded-2xl bg-zinc-100 object-cover"
            prefix={imgPrefix}
          />
        )
      }
    </div>
    <div class="lg:order-first lg:row-span-2">
      <h1 class="text-4xl leading-tight sm:leading-tight font-bold tracking-tight text-zinc-800 sm:text-5xl">
        {content[0]}
      </h1>
      <div class="mt-8 space-y-7 text-base text-zinc-600">
        {content.slice(1).map((text) => <p class="leading-relaxed">{text}</p>)}
      </div>
    </div>
    <div class="lg:pl-20 space-y-6">
      <div class="group flex justify-start gap-4">
        <TwitterIcon className="w-6 h-6 text-zinc-700 group-hover:text-violet-700" />
        <a
          href="https://x.com/darmau8964"
          target="_blank"
          rel="noreferrer"
          class="font-medium text-gray-700 group-hover:text-violet-700"
        >
          Twitter
        </a>
      </div>
      <div class="group flex justify-start gap-4">
        <GithubIcon className="w-6 h-6 text-zinc-700 group-hover:text-violet-700" />
        <a
          href="https://github.com/Darmau"
          target="_blank"
          rel="noreferrer"
          class="font-medium text-gray-700 group-hover:text-violet-700"
        >
          Github
        </a>
      </div>
      <div class="group flex justify-start gap-4">
        <InstagramIcon className="w-6 h-6 text-zinc-700 group-hover:text-violet-700" />
        <a
          href="https://www.instagram.com/ridamoe"
          target="_blank"
          rel="noreferrer"
          class="font-medium text-gray-700 group-hover:text-violet-700"
        >
          Instagram
        </a>
      </div>
      <div class="group flex justify-start gap-4">
        <YoutubeIcon className="w-6 h-6 text-zinc-700 group-hover:text-violet-700" />
        <a
          href="https://www.youtube.com/@darmau"
          target="_blank"
          rel="noreferrer"
          class="font-medium text-gray-700 group-hover:text-violet-700"
        >
          YouTube
        </a>
      </div>
    </div>
  </div>
</Layout>
