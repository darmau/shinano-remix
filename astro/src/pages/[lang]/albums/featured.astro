---
import Layout from "~/layouts/Base.astro";
import Subnav from "~/components/Subnav.astro";
import FeaturedPhotoGrid from "~/components/FeaturedPhotoGrid.tsx";
import { generatePhotoAlbum, type FeaturedPhoto } from "~/lib/photoAlbum";
import { HomepageText } from "~/locales";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import { LOCALES } from "~/lib/i18n/getLang";

export const prerender = false;

const { lang } = Astro.params;
if (!lang || !(LOCALES as readonly string[]).includes(lang)) {
  return new Response(null, { status: 404, statusText: "No such language" });
}

const supabase = Astro.locals.supabase;
const env = Astro.locals.runtime.env;
const baseUrl = env.BASE_URL;
const imgPrefix = env.IMG_PREFIX;

const table = `random_${lang}_photos` as
  | "random_zh_photos"
  | "random_en_photos"
  | "random_jp_photos";

const { data: rawFeatured, error } = await supabase
  .from(table)
  .select(
    `id, slug, title, page_view, language!inner (lang),
     cover (id, alt, storage_key, width, height)`,
  )
  .limit(32);

if (error) {
  return new Response(error.message, { status: 500 });
}

const isRecord = (value: unknown): value is Record<string, unknown> =>
  typeof value === "object" && value !== null;

const featuredPhotos: FeaturedPhoto[] = (rawFeatured ?? [])
  .map((row): FeaturedPhoto | null => {
    if (!isRecord(row)) return null;
    const id = row["id"];
    if (typeof id !== "number") return null;
    const cover = row["cover"];
    const language = row["language"];
    if (!isRecord(cover) || typeof cover["storage_key"] !== "string") return null;
    return {
      id,
      slug: typeof row["slug"] === "string" ? (row["slug"] as string) : null,
      title: typeof row["title"] === "string" ? (row["title"] as string) : "",
      language: {
        lang: isRecord(language) && typeof language["lang"] === "string"
          ? (language["lang"] as string)
          : lang,
      },
      cover: {
        id: String(cover["id"]),
        alt: typeof cover["alt"] === "string" ? (cover["alt"] as string) : null,
        storage_key: cover["storage_key"] as string,
        width: typeof cover["width"] === "number" ? (cover["width"] as number) : 0,
        height: typeof cover["height"] === "number" ? (cover["height"] as number) : 0,
      },
    };
  })
  .filter((f): f is FeaturedPhoto => f !== null);

const photos = generatePhotoAlbum(featuredPhotos, imgPrefix, lang);
const label = getLanguageLabel(HomepageText, lang);
const availableLangs = ["zh", "en", "jp"];
const ogStorage = featuredPhotos[0]?.cover.storage_key ?? "a2b148a3-5799-4be0-a8d4-907f9355f20f";
const ogImage = `${imgPrefix}/cdn-cgi/image/format=jpeg,width=960/${ogStorage}`;
---

<Layout
  lang={lang}
  title={label.featured_albums_title}
  description={label.featured_albums_description}
  ogTitle={label.featured_albums_title}
  ogDescription={label.featured_albums_description}
  ogImage={ogImage}
  pathWithoutLang="albums/featured"
  availableLangs={availableLangs}
  baseUrl={baseUrl}
  rssHref={`${baseUrl}/${lang}/album/rss.xml`}
>
  <Subnav lang={lang} active="photography" />
  <h1 class="sr-only">Featured Photography</h1>
  <div class="w-full max-w-8xl mx-auto p-4 md:py-8 lg:mb-16">
    <FeaturedPhotoGrid photos={photos} prefix={imgPrefix} />
  </div>
</Layout>
