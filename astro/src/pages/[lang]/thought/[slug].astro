---
import Layout from "~/layouts/Base.astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import type { BreadcrumbItem } from "~/components/Breadcrumb.astro";
import CommentBlock from "~/components/CommentBlock.astro";
import ContentContainer from "~/components/ContentContainer.tsx";
import Reaction from "~/components/Reaction.tsx";
import type { ReactionSummary } from "~/components/Reaction.tsx";
import CommentEditor from "~/components/CommentEditor.tsx";
import ResponsiveImage from "~/components/ResponsiveImage.tsx";
import PageViewTracker from "~/components/PageViewTracker.tsx";
import { EyeIcon } from "@heroicons/react/24/solid";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import getTime from "~/lib/i18n/getTime";
import { ThoughtText } from "~/locales";
import { LOCALES } from "~/lib/i18n/getLang";
import type { Json } from "~/types/supabase";
import type { CommentProps } from "~/types/Comment";
import type { Image } from "~/types/Image";
import {
  generateThoughtStructuredData,
  generateBreadcrumbStructuredData,
  buildCommentsStructuredData,
  serializeStructuredData,
} from "~/lib/seo/structuredData";

export const prerender = false;

const { lang, slug } = Astro.params;
if (!lang || !(LOCALES as readonly string[]).includes(lang) || !slug) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const supabase = Astro.locals.supabase;
const session = Astro.locals.session;
const env = Astro.locals.runtime.env;
const baseUrl = env.BASE_URL;
const imgPrefix = env.IMG_PREFIX;

const url = new URL(Astro.request.url);
const page = url.searchParams.get("page") ? parseInt(url.searchParams.get("page")!) : 1;
const limit = url.searchParams.get("limit") ? parseInt(url.searchParams.get("limit")!) : 20;

const { data: thoughtData } = await supabase
  .from("thought")
  .select(`id, content_json, content_text, slug, page_view, reactions, created_at`)
  .eq("slug", slug)
  .single();

if (!thoughtData) {
  return new Response(null, { status: 404, statusText: "Thought not exists" });
}

const [thoughtImagesResult, commentsResult, commentCountResult] = await Promise.all([
  supabase
    .from("thought_image")
    .select(`order, image (id, alt, storage_key, width, height, caption)`)
    .eq("thought_id", thoughtData.id)
    .order("order", { ascending: true }),
  supabase
    .from("comment")
    .select(
      `id, user_id, name, website, content_text, created_at, is_anonymous,
       users (id, name, role, website),
       reply_to (id, content_text, is_anonymous, name, users (id, name))`,
    )
    .eq("to_thought", thoughtData.id)
    .eq("is_blocked", false)
    .eq("is_public", true)
    .order("created_at", { ascending: false })
    .range((page - 1) * limit, page * limit - 1),
  supabase
    .from("comment")
    .select("id", { count: "exact" })
    .eq("to_thought", thoughtData.id)
    .eq("is_blocked", false)
    .eq("is_public", true),
]);

const thoughtImages = thoughtImagesResult.data ?? [];
const comments = (commentsResult.data ?? []) as unknown as CommentProps[];
const count = commentCountResult.count ?? 0;
const totalPage = count ? Math.ceil(count / limit) : 1;

const label = getLanguageLabel(ThoughtText, lang);
const availableLangs = ["zh", "en", "jp"];
const currentUrl = `${baseUrl}/${lang}/thought/${slug}`;
const pageViewNodeId = `thought-${thoughtData.id}-page-view`;

const breadcrumbPages: BreadcrumbItem[] = [
  { name: label.all_thoughts, to: `thoughts`, current: false },
  {
    name: thoughtData.content_text
      ? `${thoughtData.content_text.slice(0, 10)}...`
      : "",
    to: `thought/${thoughtData.slug}`,
    current: true,
  },
];

const processedImages = thoughtImages
  .map((item) => {
    const image = (item as { image: unknown }).image;
    if (!image || typeof image !== "object") return null;
    const img = image as {
      alt?: string | null;
      storage_key?: string;
      width?: number;
      height?: number;
    };
    if (!img.storage_key) return null;
    return {
      alt: img.alt ?? null,
      storage_key: img.storage_key,
      width: img.width ?? 0,
      height: img.height ?? 0,
    };
  })
  .filter((img): img is NonNullable<typeof img> => img !== null);

const thoughtJsonLd = generateThoughtStructuredData({
  thought: {
    id: thoughtData.id || 0,
    slug: thoughtData.slug || "",
    content_text: thoughtData.content_text || "",
    created_at: thoughtData.created_at || new Date().toISOString(),
    page_view: thoughtData.page_view || 0,
    images: processedImages,
    comments: [{ count }],
  },
  baseUrl,
  imgPrefix,
  lang,
  url: currentUrl,
});

const breadcrumbJsonLd = generateBreadcrumbStructuredData([
  { name: "Home", url: `${baseUrl}/${lang}` },
  { name: "Thoughts", url: `${baseUrl}/${lang}/thoughts` },
  {
    name: thoughtData.content_text ? thoughtData.content_text.slice(0, 50) : "Thought",
    url: currentUrl,
  },
]);

const commentJsonLd = buildCommentsStructuredData(
  comments as unknown as Parameters<typeof buildCommentsStructuredData>[0],
  baseUrl,
  currentUrl,
);

const title = getTime(thoughtData.created_at!, lang);
const description = thoughtData.content_text
  ? thoughtData.content_text.split(/\r?\n/).join("")
  : "";
---

<Layout
  lang={lang}
  title={title}
  description={description}
  ogTitle={title}
  ogDescription={description}
  ogType="article"
  pathWithoutLang={`thought/${slug}`}
  availableLangs={availableLangs}
  baseUrl={baseUrl}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeStructuredData(thoughtJsonLd)}
    slot="head"
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeStructuredData(breadcrumbJsonLd)}
    slot="head"
  />
  {
    commentJsonLd.map((c) => (
      <script
        is:inline
        type="application/ld+json"
        set:html={serializeStructuredData(c)}
        slot="head"
      />
    ))
  }

  <div class="w-full max-w-6xl mx-auto p-4 md:py-8 mb-8 lg:mb-16">
    <Breadcrumb lang={lang} pages={breadcrumbPages} />
    <h1 class="sr-only">{title}</h1>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="col-span-1 lg:col-span-2">
        {
          thoughtData.content_json && (
            <ContentContainer
              client:visible
              content={thoughtData.content_json as Json}
              prefix={imgPrefix}
            />
          )
        }
        {
          processedImages.length > 0 && (
            <div class="space-y-2 mt-4">
              {processedImages.map((img) => (
                <ResponsiveImage
                  client:visible
                  image={img as Image}
                  width={560}
                  classList="rounded"
                  prefix={imgPrefix}
                />
              ))}
            </div>
          )
        }
        <div class="flex justify-start items-center gap-1 mt-4">
          <div class="flex gap-1 items-center justify-start">
            <EyeIcon className="h-4 w-4 inline-block text-zinc-500" />
            <p id={pageViewNodeId} class="text-zinc-500 text-sm">{thoughtData.page_view}</p>
          </div>
          ·
          <p class="text-sm text-zinc-500">{getTime(thoughtData.created_at!, lang)}</p>
        </div>
        <Reaction
          client:load
          contentType="thought"
          contentId={thoughtData.id}
          reactions={thoughtData.reactions as ReactionSummary | null}
          className="mt-6"
          pathname={Astro.url.pathname}
          supabaseUrl={env.SUPABASE_URL}
          supabaseAnonKey={env.SUPABASE_ANON_KEY}
        />
      </div>

      <div class="col-span-1 space-y-4">
        <CommentEditor
          client:load
          contentTable="to_thought"
          contentId={thoughtData.id}
          session={session}
          lang={lang}
          turnstileSiteKey={env.TURNSTILE_SITE_KEY}
          endpoint="/api/comments"
        />
        <div class="flex flex-col gap-4 divide-y divide-none">
          {comments.map((comment) => <CommentBlock comment={comment} lang={lang} />)}
        </div>
        <div class="py-8 flex justify-between">
          {
            page > 1 && (
              <a
                href={`?page=${page - 1}&limit=${limit}#comment-editor`}
                class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50"
              >
                {label.previous}
              </a>
            )
          }
          {
            page < totalPage && (
              <a
                href={`?page=${page + 1}&limit=${limit}#comment-editor`}
                class="ml-auto rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50"
              >
                {label.next}
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>

  <PageViewTracker
    client:idle
    contentType="thought"
    contentId={thoughtData.id}
    countNodeId={pageViewNodeId}
    supabaseUrl={env.SUPABASE_URL}
    supabaseAnonKey={env.SUPABASE_ANON_KEY}
  />
</Layout>
