---
import Layout from "~/layouts/Base.astro";
import Subnav from "~/components/Subnav.astro";
import RSSCopyButton from "~/components/RSSCopyButton.tsx";
import { RSSText } from "~/locales";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import { LOCALES } from "~/lib/i18n/getLang";

export const prerender = false;

const { lang } = Astro.params;
if (!lang || !(LOCALES as readonly string[]).includes(lang)) {
  return new Response(null, { status: 404, statusText: "No such language" });
}

const supabase = Astro.locals.supabase;
const env = Astro.locals.runtime.env;
const baseUrl = env.BASE_URL;
const imgPrefix = env.IMG_PREFIX;
const label = getLanguageLabel(RSSText, lang);

const [articlesResult, photosResult, thoughtsResult] = await Promise.all([
  supabase
    .from("article")
    .select(`id, title, subtitle, published_at, language!inner (lang)`)
    .eq("is_draft", false)
    .eq("language.lang", lang)
    .order("published_at", { ascending: false })
    .limit(5),
  supabase
    .from("photo")
    .select(`id, title, published_at, language!inner (lang), cover (storage_key)`)
    .eq("is_draft", false)
    .eq("is_featured", true)
    .eq("language.lang", lang)
    .order("published_at", { ascending: false })
    .limit(9),
  supabase
    .from("thought")
    .select(`id, content_text, created_at`)
    .order("created_at", { ascending: false })
    .limit(7),
]);

const articles = articlesResult.data ?? [];
const photos = photosResult.data ?? [];
const thoughts = thoughtsResult.data ?? [];

const availableLangs = ["zh", "en", "jp"];

const articleRssUrl = `${baseUrl}/${lang}/article/rss.xml`;
const photoRssUrl = `${baseUrl}/${lang}/album/rss.xml`;
const thoughtRssUrl = `${baseUrl}/${lang}/thought/rss.xml`;
---

<Layout
  lang={lang}
  title={label.page_title}
  description={label.page_description}
  ogTitle={label.page_title}
  ogDescription={label.page_description}
  pathWithoutLang="rss"
  availableLangs={availableLangs}
  baseUrl={baseUrl}
>
  <Subnav lang={lang} active="about" />
  <div class="w-full max-w-8xl mx-auto p-4 md:py-8 my-8">
    <header class="text-center space-y-2 mb-12">
      <h2 class="font-medium text-sm text-violet-700">RSS</h2>
      <h1 class="font-medium text-zinc-900 text-3xl lg:text-4xl">{label.title}</h1>
      <p class="text-base text-zinc-600">{label.description}</p>
    </header>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <section class="rounded-2xl border border-gray-200 shadow-lg">
        <div class="p-4 lg:p-8 border-b border-gray-200 space-y-4">
          <h3 class="font-medium text-lg text-zinc-700">{label.article}</h3>
          <code class="text-sm block font-mono text-zinc-600">{articleRssUrl}</code>
          <RSSCopyButton
            client:load
            url={articleRssUrl}
            copyLabel={label.copy}
            copiedLabel={label.copied}
          />
        </div>
        {
          articles.length > 0 && (
            <ol class="space-y-4 p-4 lg:p-8">
              {articles.map((article) => (
                <li>
                  <h4 class="font-medium text-zinc-700">{article.title}</h4>
                  <p class="text-zinc-500 mt-1">{article.subtitle}</p>
                </li>
              ))}
            </ol>
          )
        }
      </section>
      <section class="rounded-2xl border border-gray-200 shadow-lg">
        <div class="p-4 lg:p-8 border-b border-gray-200 space-y-4">
          <h3 class="font-medium text-lg text-zinc-700">{label.photography}</h3>
          <code class="text-sm block font-mono text-zinc-600">{photoRssUrl}</code>
          <RSSCopyButton
            client:load
            url={photoRssUrl}
            copyLabel={label.copy}
            copiedLabel={label.copied}
          />
        </div>
        <div class="grid grid-cols-3 gap-2 mt-8 p-4 lg:p-8">
          {
            photos.map(
              (photo) =>
                photo.cover && (
                  <div class="aspect-square overflow-hidden rounded">
                    <img
                      src={`${imgPrefix}/cdn-cgi/image/format=auto,width=240/${(photo.cover as { storage_key: string }).storage_key}`}
                      alt={photo.title ?? ""}
                      class="w-full h-full object-cover"
                    />
                  </div>
                ),
            )
          }
        </div>
      </section>
      <section class="rounded-2xl border border-gray-200 shadow-lg">
        <div class="p-4 lg:p-8 border-b border-gray-200 space-y-4">
          <h3 class="font-medium text-lg text-zinc-700">{label.thought}</h3>
          <code class="text-sm block font-mono text-zinc-600">{thoughtRssUrl}</code>
          <RSSCopyButton
            client:load
            url={thoughtRssUrl}
            copyLabel={label.copy}
            copiedLabel={label.copied}
          />
        </div>
        {
          thoughts.length > 0 && (
            <ol class="space-y-4 p-4 lg:p-8 pl-8 lg:pl-12 list-decimal">
              {thoughts.map((thought) => (
                <li>
                  <p class="text-zinc-700">{thought.content_text}</p>
                </li>
              ))}
            </ol>
          )
        }
      </section>
    </div>
  </div>
</Layout>
