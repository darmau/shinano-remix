---
import "~/styles/global.css";
import Navbar from "~/components/Navbar.tsx";
import Banners from "~/components/Banners.tsx";
import AuthProvider from "~/components/AuthProvider.tsx";
import Footer from "~/components/Footer.astro";
import { NavbarItems, ProfileText } from "~/locales";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import i18nLinks from "~/lib/seo/i18nLinks";
import {
  generateWebsiteStructuredData,
  serializeStructuredData,
} from "~/lib/seo/structuredData";

export interface Props {
  lang: string;
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  twitterCard?: "summary" | "summary_large_image";
  twitterCreator?: string;
  /** path *without* the leading /lang segment, e.g. "article/foo" */
  pathWithoutLang: string;
  /** language codes that this content is available in (for hreflang) */
  availableLangs: string[];
  /** absolute base URL, e.g. https://darmau.co */
  baseUrl: string;
  /** optional <link rel="alternate" type="application/rss+xml"> href */
  rssHref?: string;
}

const {
  lang,
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = "website",
  twitterCard = "summary_large_image",
  twitterCreator = "@darmau8964",
  pathWithoutLang,
  availableLangs,
  baseUrl,
  rssHref,
} = Astro.props;

const SITE_NAMES: Record<string, string> = { zh: "积薪", en: "Firewood", jp: "積薪" };
const siteName = SITE_NAMES[lang] ?? "积薪";
const alternateNames = ["积薪", "Firewood", "積薪", "darmau.co"].filter((n) => n !== siteName);

const websiteJsonLd = generateWebsiteStructuredData({
  baseUrl,
  name: siteName,
  alternateName: alternateNames,
  inLanguage: lang,
});

const links = i18nLinks(baseUrl, lang, availableLangs, pathWithoutLang);
const canonicalUrl = `${baseUrl}/${lang}/${pathWithoutLang}`.replace(/\/$/, "");
const ogUrl = canonicalUrl;

const env = Astro.locals.runtime.env;
const session = Astro.locals.session;
const navbarItems = NavbarItems(lang);
const profileLabel = getLanguageLabel(ProfileText, lang);
const currentYear = new Date().getFullYear();

const user = session
  ? {
      id: session.user.id,
      name: session.user.user_metadata?.name as string | undefined,
      email: session.user.user_metadata?.email as string | undefined,
    }
  : null;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <meta property="og:site_name" content={siteName} />
    <meta name="application-name" content={siteName} />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <meta property="og:title" content={ogTitle ?? title} />
    {ogDescription && <meta property="og:description" content={ogDescription} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta property="twitter:card" content={twitterCard} />
    <meta property="twitter:title" content={ogTitle ?? title} />
    {ogDescription && <meta property="twitter:description" content={ogDescription} />}
    {ogImage && <meta property="twitter:image" content={ogImage} />}
    <meta property="twitter:creator" content={twitterCreator} />

    {rssHref && (
      <link rel="alternate" type="application/rss+xml" title="RSS" href={rssHref} />
    )}

    {
      links.map((link) =>
        "tagName" in link ? (
          link.rel === "canonical" ? (
            <link rel="canonical" href={link.href} />
          ) : (
            <link rel="alternate" href={link.href} hreflang={link.hrefLang} />
          )
        ) : (
          <meta property={link.property} content={link.content} />
        ),
      )
    }

    <script
      type="application/ld+json"
      set:html={serializeStructuredData(websiteJsonLd)}
    />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col relative">
    <Navbar
      client:load
      lang={lang}
      items={navbarItems}
      pathname={Astro.url.pathname}
      availableLangs={availableLangs}
      user={user}
      profileLabel={profileLabel}
    />
    <main class="flex-1 w-full mt-[76px]">
      <Banners client:load lang={lang} />
      <slot />
    </main>
    <Footer lang={lang} currentYear={currentYear} />
    <AuthProvider
      client:load
      supabaseUrl={env.SUPABASE_URL}
      supabaseAnonKey={env.SUPABASE_ANON_KEY}
      serverAccessToken={session?.access_token ?? null}
    />
  </body>
</html>
