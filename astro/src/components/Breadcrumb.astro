---
import { HomeIcon } from "@heroicons/react/24/solid";

export interface BreadcrumbItem {
  name: string;
  to: string;
  current?: boolean;
}

interface Props {
  lang: string;
  pages: BreadcrumbItem[];
}

const { lang, pages } = Astro.props;
const homeLabel = lang === "zh" ? "首页" : lang === "jp" ? "ホーム" : "Home";
---

<nav aria-label="Breadcrumb" class="flex my-4">
  <ol class="flex items-center space-x-4">
    <li>
      <div>
        <a href={`/${lang}`} class="text-gray-400 hover:text-gray-500" aria-label={homeLabel}>
          <HomeIcon aria-hidden="true" className="h-5 w-5 shrink-0" />
        </a>
      </div>
    </li>
    {
      pages.map((page) => (
        <li>
          <div class="flex items-center">
            <svg fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" class="h-5 w-5 shrink-0 text-gray-300">
              <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
            <a
              href={`/${lang}/${page.to}`}
              aria-current={page.current ? "page" : undefined}
              class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700"
            >
              {page.name}
            </a>
          </div>
        </li>
      ))
    }
  </ol>
</nav>
