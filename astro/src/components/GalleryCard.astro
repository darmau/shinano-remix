---
import type { GalleryItem } from "~/types/Gallery";
import getTime from "~/lib/i18n/getTime";

interface Props {
  item: GalleryItem;
  lang: string;
  prefix: string;
}

const { item, lang, prefix } = Astro.props;

function getGridClass(count: number): string {
  if (count === 1) return "grid-cols-1";
  if (count === 2) return "grid-cols-2";
  if (count === 3) return "grid-cols-3";
  if (count === 4) return "grid-cols-2";
  return "grid-cols-3";
}

const href =
  item.type === "photo"
    ? `/${lang}/album/${item.slug ?? item.id}`
    : `/${lang}/thought/${item.slug ?? item.id}`;
const images = item.images;
const displayImages = images.slice(0, 9);
const remainingCount = images.length - 9;
const gridClass = getGridClass(images.length);
---

{
  images.length > 0 && (
    <li class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        {item.type === "photo" && item.title && (
          <a
            href={href}
            class="text-xl font-medium text-zinc-900 hover:text-zinc-600 transition-colors"
          >
            {item.title}
          </a>
        )}
      </div>

      {item.type === "thought" && item.content && (
        <a href={href} class="block text-sm text-zinc-700 line-clamp-3">
          {item.content}
        </a>
      )}

      <time class="text-sm text-zinc-500 tabular-nums">
        {getTime(item.createdAt, lang)}
      </time>

      <a href={href} class:list={["grid", gridClass, "gap-1 rounded-lg overflow-hidden"]}>
        {displayImages.map((image, index) => {
          const isLastWithMore = index === 8 && remainingCount > 0;
          return (
            <div class="relative overflow-hidden aspect-square">
              <img
                src={`${prefix}/cdn-cgi/image/format=auto,width=720/${image.storage_key}`}
                alt={image.alt ?? ""}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
              {isLastWithMore && (
                <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
                  <span class="text-white text-2xl font-semibold">+{remainingCount}</span>
                </div>
              )}
            </div>
          );
        })}
      </a>
    </li>
  )
}
