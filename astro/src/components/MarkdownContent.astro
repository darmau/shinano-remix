---
import { marked } from "marked";

interface Props {
  content: string;
}

const { content } = Astro.props;

function escapeHtml(input: string) {
  return input
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

const escaped = escapeHtml(content);
const rendered = marked.parse(escaped, { gfm: true, breaks: true });
const html = typeof rendered === "string" ? rendered : "";
---

<div class="comment-markdown" set:html={html} />
