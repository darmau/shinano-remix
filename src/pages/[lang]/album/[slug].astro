---
import Layout from "~/layouts/Base.astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import type { BreadcrumbItem } from "~/components/Breadcrumb.astro";
import Comments from "~/components/Comments.astro";
import ContentContainer from "~/components/ContentContainer.tsx";
import Reaction from "~/components/Reaction.tsx";
import type { ReactionSummary } from "~/components/Reaction.tsx";
import ShareButton from "~/components/ShareButton.tsx";
import PageViewTracker from "~/components/PageViewTracker.tsx";
import GallerySlide from "~/components/GallerySlide.tsx";
import type { AlbumPhoto } from "~/components/GallerySlide.tsx";
import Mapbox from "~/components/Mapbox.tsx";
import { EyeIcon } from "@heroicons/react/24/solid";
import { MapPinIcon } from "@heroicons/react/20/solid";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import getTime from "~/lib/i18n/getTime";
import { AlbumText } from "~/locales";
import type { Json } from "~/types/supabase";
import { LOCALES } from "~/lib/i18n/getLang";
import { getPublicEnv } from "~/lib/env";
import { createSupabaseBuild } from "~/lib/supabase/build";
import {
  generateAlbumStructuredData,
  generateBreadcrumbStructuredData,
  serializeStructuredData,
} from "~/lib/seo/structuredData";

export const prerender = true;

export async function getStaticPaths() {
  const sb = createSupabaseBuild();
  const { data } = await sb
    .from("photo")
    .select("slug, language!inner (lang)")
    .eq("is_draft", false);
  const entries: { params: { lang: string; slug: string } }[] = [];
  for (const row of (data ?? []) as { slug: string | null; language: { lang: string | null } | null }[]) {
    if (!row.slug || !row.language?.lang) continue;
    entries.push({ params: { lang: row.language.lang, slug: row.slug } });
  }
  return entries;
}

const { lang, slug } = Astro.params;
const supabase = createSupabaseBuild();
const env = getPublicEnv(Astro.locals);
const baseUrl = env.BASE_URL;
const imgPrefix = env.IMG_PREFIX;
const mapboxToken = (Astro.locals.runtime?.env as { MAPBOX_TOKEN?: string } | undefined)?.MAPBOX_TOKEN
  ?? process.env.MAPBOX_TOKEN
  ?? "";

const { data: albumContent } = await supabase
  .from("photo")
  .select(
    `id, title, slug, abstract, published_at, content_json, content_text, topic,
     page_view, reactions,
     category (title, slug),
     language!inner (lang)`,
  )
  .eq("slug", slug!)
  .eq("language.lang", lang!)
  .single();

if (!albumContent) {
  return new Response(null, { status: 404, statusText: "Album not exists" });
}

const [imagesResult, commentCountResult, availableAlbumsResult] = await Promise.all([
  supabase
    .from("photo_image")
    .select(
      `order, image (alt, caption, height, width, storage_key, exif, location, latitude, longitude)`,
    )
    .eq("photo_id", albumContent.id)
    .order("order", { ascending: true }),
  supabase
    .from("comment")
    .select("id", { count: "exact", head: true })
    .eq("to_photo", albumContent.id)
    .eq("is_blocked", false)
    .eq("is_public", true),
  supabase.from("photo").select(`language!inner (lang)`).eq("slug", slug!),
]);

const albumImages = (imagesResult.data ?? []) as unknown as AlbumPhoto[];
const count = commentCountResult.count ?? 0;
const availableLangs = (availableAlbumsResult.data ?? [])
  .map((item) => (item.language as { lang: string | null } | null)?.lang)
  .filter((l): l is string => Boolean(l));

const label = getLanguageLabel(AlbumText, lang!);
const currentUrl = `${baseUrl}/${lang}/album/${slug}`;
const pageViewNodeId = `album-${albumContent.id}-page-view`;

const breadcrumbPages: BreadcrumbItem[] = [
  { name: label.latest_albums, to: `albums/all/1`, current: false },
  { name: albumContent.title ?? "", to: `album/${albumContent.slug}`, current: true },
];

const firstImage = albumImages[0]?.image;
const firstCoords = firstImage
  ? { latitude: firstImage.latitude ?? null, longitude: firstImage.longitude ?? null }
  : { latitude: null, longitude: null };

const processedImages = albumImages
  .map((entry, idx) => {
    const img = entry.image;
    if (!img) return null;
    return {
      id: idx,
      alt: img.alt ?? null,
      caption: img.caption ?? null,
      storage_key: img.storage_key,
      width: img.width,
      height: img.height,
      exif: img.exif,
      location: img.location ?? null,
      latitude: img.latitude ?? null,
      longitude: img.longitude ?? null,
    };
  })
  .filter((img): img is NonNullable<typeof img> => img !== null);

const albumJsonLd = generateAlbumStructuredData({
  album: {
    id: albumContent.id || 0,
    title: albumContent.title || "",
    slug: albumContent.slug || "",
    abstract: albumContent.abstract,
    published_at: albumContent.published_at || new Date().toISOString(),
    page_view: albumContent.page_view || 0,
    images: processedImages,
    comments: [{ count }],
  },
  baseUrl,
  imgPrefix,
  lang: lang!,
  url: currentUrl,
});

const breadcrumbJsonLd = generateBreadcrumbStructuredData([
  { name: "Home", url: `${baseUrl}/${lang}` },
  { name: "Albums", url: `${baseUrl}/${lang}/albums/all/1` },
  { name: albumContent.title || "Album", url: currentUrl },
]);

const ogImage = firstImage
  ? `${imgPrefix}/cdn-cgi/image/format=jpeg,width=960/${firstImage.storage_key}`
  : undefined;
---

<Layout
  lang={lang!}
  title={albumContent.title ?? ""}
  description={albumContent.abstract ?? albumContent.content_text ?? undefined}
  ogTitle={albumContent.title ?? undefined}
  ogDescription={albumContent.abstract ?? albumContent.content_text ?? undefined}
  ogImage={ogImage}
  ogType="article"
  pathWithoutLang={`album/${slug}`}
  availableLangs={availableLangs}
  baseUrl={baseUrl}
  rssHref={`${baseUrl}/${lang}/album/rss.xml`}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeStructuredData(albumJsonLd)}
    slot="head"
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeStructuredData(breadcrumbJsonLd)}
    slot="head"
  />

  <div class="w-full max-w-8xl mx-auto p-4 md:py-8 lg:mb-16">
    <Breadcrumb lang={lang!} pages={breadcrumbPages} />
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="col-span-1 lg:col-span-2 lg:self-start">
        {
          albumImages.length > 0 && (
            <GallerySlide client:load albumImages={albumImages} prefix={imgPrefix} />
          )
        }
      </div>

      <div class="col-span-1 lg:row-span-2 space-y-4">
        <h2 class="text-sm text-violet-700 font-medium">{albumContent.category?.title}</h2>
        <h1 class="text-zinc-800 font-medium text-3xl">{albumContent.title}</h1>
        <p class="text-zinc-600 text-sm">{getTime(albumContent.published_at!, lang!)}</p>
        <div class="flex gap-1 items-center justify-start">
          <EyeIcon className="h-4 w-4 inline-block text-zinc-500" />
          <p id={pageViewNodeId} class="text-zinc-500 text-sm">{albumContent.page_view}</p>
        </div>

        {
          albumContent.content_json && (
            <ContentContainer
              client:visible
              content={albumContent.content_json as Json}
              prefix={imgPrefix}
            />
          )
        }
        {
          albumContent.topic && (
            <ol class="flex gap-2 flex-wrap">
              {albumContent.topic.map((topic: string) => (
                <li class="text-sm text-zinc-600">#{topic}</li>
              ))}
            </ol>
          )
        }

        <Reaction
          client:load
          contentType="photo"
          contentId={albumContent.id}
          reactions={albumContent.reactions as ReactionSummary | null}
          pathname={`/${lang}/album/${slug}`}
          supabaseUrl={env.SUPABASE_URL}
          supabaseAnonKey={env.SUPABASE_ANON_KEY}
        />

        {
          firstImage?.location && (
            <div class="flex gap-2 justify-start items-center">
              <MapPinIcon className="w-6 h-6 text-violet-700 inline-block" />
              <p class="text-sm text-zinc-500">{firstImage.location}</p>
            </div>
          )
        }
        {
          (firstCoords.latitude || firstCoords.longitude) && mapboxToken && (
            <Mapbox
              client:visible
              mapboxToken={mapboxToken}
              coords={firstCoords}
              lang={lang!}
            />
          )
        }

        <ShareButton client:load url={currentUrl} title={albumContent.title ?? ""} lang={lang!} contentType="album" />
      </div>

      <div class="col-span-1 lg:col-span-2 lg:self-start">
        <Comments
          server:defer
          contentTable="to_photo"
          contentId={albumContent.id}
          lang={lang!}
        />
      </div>
    </div>
  </div>

  <PageViewTracker
    client:idle
    contentType="album"
    contentId={albumContent.id}
    countNodeId={pageViewNodeId}
    supabaseUrl={env.SUPABASE_URL}
    supabaseAnonKey={env.SUPABASE_ANON_KEY}
  />
</Layout>
