---
import Layout from "~/layouts/Base.astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import type { BreadcrumbItem } from "~/components/Breadcrumb.astro";
import NextAndPrev from "~/components/NextAndPrev.astro";
import type { NeighboringPost } from "~/components/NextAndPrev.astro";
import Comments from "~/components/Comments.astro";
import Catalog from "~/components/Catalog.astro";
import ReadingProcess from "~/components/ReadingProcess.tsx";
import ContentContainer from "~/components/ContentContainer.tsx";
import Reaction from "~/components/Reaction.tsx";
import type { ReactionSummary } from "~/components/Reaction.tsx";
import ResponsiveImage from "~/components/ResponsiveImage.tsx";
import PageViewTracker from "~/components/PageViewTracker.tsx";
import ArticlePremiumGate from "~/components/ArticlePremiumGate.astro";
import { EyeIcon } from "@heroicons/react/24/solid";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import getTime from "~/lib/i18n/getTime";
import { ArticleText } from "~/locales";
import type { Json } from "~/types/supabase";
import type { Image } from "~/types/Image";
import { LOCALES } from "~/lib/i18n/getLang";
import { getPublicEnv } from "~/lib/env";
import { createSupabaseBuild } from "~/lib/supabase/build";
import {
  generateArticleStructuredData,
  generateBreadcrumbStructuredData,
  serializeStructuredData,
} from "~/lib/seo/structuredData";

export const prerender = true;

export async function getStaticPaths() {
  const sb = createSupabaseBuild();
  const { data } = await sb
    .from("article")
    .select("slug, language!inner (lang)")
    .eq("is_draft", false);
  const entries: { params: { lang: string; slug: string } }[] = [];
  for (const row of (data ?? []) as { slug: string | null; language: { lang: string | null } | null }[]) {
    if (!row.slug || !row.language?.lang) continue;
    entries.push({ params: { lang: row.language.lang, slug: row.slug } });
  }
  return entries;
}

const { lang, slug } = Astro.params;
const supabase = createSupabaseBuild();
const env = getPublicEnv(Astro.locals);
const baseUrl = env.BASE_URL;
const imgPrefix = env.IMG_PREFIX;

const { data: article } = await supabase
  .from("article")
  .select(
    `
    id, title, slug, subtitle, abstract, updated_at, published_at,
    is_premium, is_featured, is_top, topic, content_json, page_view, reactions,
    category (title, slug),
    cover (alt, height, width, storage_key),
    language!inner (lang),
    lang
  `,
  )
  .eq("slug", slug!)
  .eq("language.lang", lang!)
  .single();

if (!article) {
  return new Response(null, { status: 404, statusText: "Article not exists" });
}

const [
  previousArticleResult,
  nextArticleResult,
  commentCountResult,
  availableArticleResult,
] = await Promise.all([
  supabase
    .from("article")
    .select("title, slug, subtitle")
    .eq("lang", article.lang!)
    .lt("published_at", article.published_at!)
    .order("published_at", { ascending: false })
    .limit(1)
    .maybeSingle(),
  supabase
    .from("article")
    .select("title, slug")
    .eq("lang", article.lang!)
    .gt("published_at", article.published_at!)
    .order("published_at", { ascending: true })
    .limit(1)
    .maybeSingle(),
  supabase
    .from("comment")
    .select("id", { count: "exact", head: true })
    .eq("to_article", article.id)
    .eq("is_blocked", false)
    .eq("is_public", true),
  supabase
    .from("article")
    .select(`language!inner (lang)`)
    .eq("slug", slug!),
]);

const previousArticle = (previousArticleResult.data ?? null) as NeighboringPost | null;
const nextArticle = (nextArticleResult.data ?? null) as NeighboringPost | null;
const count = commentCountResult.count ?? 0;
const availableArticle = availableArticleResult.data ?? [];

const availableLangs = availableArticle
  .map((item) => (item.language as { lang: string | null } | null)?.lang)
  .filter((l): l is string => Boolean(l));

const currentUrl = `${baseUrl}/${lang}/article/${slug}`;
const label = getLanguageLabel(ArticleText, lang!);

const isPremiumArticle = article.is_premium === true;

const breadcrumbPages: BreadcrumbItem[] = [
  { name: label.latest_articles, to: `articles/1`, current: false },
  { name: article.title!, to: `article/${article.slug}`, current: true },
];

const articleJsonLd = generateArticleStructuredData({
  article: {
    id: article.id,
    title: article.title || "",
    slug: article.slug || "",
    subtitle: article.subtitle,
    abstract: article.abstract,
    is_featured: article.is_featured,
    is_premium: article.is_premium,
    topic: article.topic,
    published_at: article.published_at || new Date().toISOString(),
    updated_at: article.updated_at,
    page_view: article.page_view || 0,
    cover: article.cover
      ? {
          alt: article.cover.alt,
          storage_key: article.cover.storage_key,
          width: article.cover.width || 0,
          height: article.cover.height || 0,
        }
      : null,
    category: {
      title: article.category?.title || "",
      slug: article.category?.slug || "",
    },
    comments: [{ count }],
    content_json: article.content_json,
  },
  baseUrl,
  imgPrefix,
  lang: lang!,
  url: currentUrl,
});

const breadcrumbJsonLd = generateBreadcrumbStructuredData([
  { name: "Home", url: `${baseUrl}/${lang}` },
  { name: "Articles", url: `${baseUrl}/${lang}/articles/1` },
  { name: article.title || "Article", url: currentUrl },
]);

const ogImage = `${imgPrefix}/cdn-cgi/image/format=jpeg,width=960/${
  article.cover?.storage_key ?? "a2b148a3-5799-4be0-a8d4-907f9355f20f"
}`;

const pageViewNodeId = `article-${article.id}-page-view`;
---

<Layout
  lang={lang!}
  title={article.title!}
  description={article.abstract ?? article.subtitle ?? undefined}
  ogTitle={article.title!}
  ogDescription={article.subtitle ?? undefined}
  ogImage={ogImage}
  ogType="article"
  pathWithoutLang={`article/${article.slug}`}
  availableLangs={availableLangs}
  baseUrl={baseUrl}
  rssHref={`${baseUrl}/${lang}/article/rss.xml`}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeStructuredData(articleJsonLd)}
    slot="head"
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeStructuredData(breadcrumbJsonLd)}
    slot="head"
  />

  <div class="w-full max-w-6xl mx-auto p-4 md:py-8 mb-8 lg:mb-16">
    <ReadingProcess client:load />
    <Breadcrumb lang={lang!} pages={breadcrumbPages} />

    <div class="flex flex-col gap-8 md:gap-16">
      <div class="grid grid-cols-1 md:grid-cols-2 grid-rows-1 mt-4 gap-6 md:gap-8">
        <header class="space-y-4">
          <div class="flex gap-4 flex-wrap justify-start items-center">
            <h3 class="text-sm text-violet-700 font-medium">{article.category!.title}</h3>
            <time class="text-zinc-600 text-sm">{getTime(article.published_at!, lang!)}</time>
          </div>
          <div class="flex items-center gap-3 text-zinc-800">
            <h1 class="font-medium leading-normal text-4xl lg:text-5xl">{article.title}</h1>
          </div>
          <h2 class="text-zinc-600 text-lg lg:text-xl">{article.subtitle}</h2>
          {
            article.abstract && (
              <p class="p-4 rounded-md bg-zinc-100 text-zinc-600 leading-normal text-sm lg:text-base">
                {article.abstract}
              </p>
            )
          }
          {
            article.topic && (
              <ol class="flex gap-2 flex-wrap">
                {article.topic.map((topic: string) => (
                  <li class="text-sm text-zinc-600">#{topic}</li>
                ))}
              </ol>
            )
          }
          <div class="flex gap-1 items-center justify-start">
            <EyeIcon className="h-4 w-4 inline-block text-zinc-500" />
            <p id={pageViewNodeId} class="text-zinc-500 text-sm">{article.page_view}</p>
          </div>
        </header>
        {
          article.cover && (
            <ResponsiveImage
              client:load
              image={article.cover as unknown as Image}
              width={960}
              classList="w-full rounded-md overflow-hiden object-cover aspect-3/2"
              prefix={imgPrefix}
            />
          )
        }
      </div>

      <div class="relative grid grid-cols-1 md:grid-cols-3 md:gap-24">
        <div class="col-span-1 md:col-span-2 selection:bg-violet-800/60 selection:text-white">
          <div class="flex flex-col">
            {
              isPremiumArticle ? (
                <ArticlePremiumGate
                  server:defer
                  articleId={article.id}
                  lang={lang!}
                />
              ) : (
                article.content_json && (
                  <ContentContainer
                    client:visible
                    content={article.content_json as Json}
                    prefix={imgPrefix}
                  />
                )
              )
            }

            <Reaction
              client:load
              contentType="article"
              contentId={article.id}
              reactions={article.reactions as ReactionSummary | null}
              className="mt-10"
              pathname={`/${lang}/article/${slug}`}
              supabaseUrl={env.SUPABASE_URL}
              supabaseAnonKey={env.SUPABASE_ANON_KEY}
            />

            <NextAndPrev type="article" lang={lang!} prev={previousArticle} next={nextArticle} />

            <div class="mt-16 col-span-1 lg:col-span-2">
              <Comments
                server:defer
                contentTable="to_article"
                contentId={article.id}
                lang={lang!}
              />
            </div>
          </div>
        </div>

        {
          !isPremiumArticle && article.content_json && (
            <aside class="hidden md:flex md:col-span-1 md:h-full">
              <Catalog
                content={article.content_json as Json}
                url={currentUrl}
                title={article.title!}
                lang={lang!}
              />
            </aside>
          )
        }
      </div>
    </div>
  </div>

  <PageViewTracker
    client:idle
    contentType="article"
    contentId={article.id}
    countNodeId={pageViewNodeId}
    supabaseUrl={env.SUPABASE_URL}
    supabaseAnonKey={env.SUPABASE_ANON_KEY}
  />
</Layout>
