---
import Layout from "~/layouts/Base.astro";
import Subnav from "~/components/Subnav.astro";
import RateStars from "~/components/RateStars.astro";
import getDate from "~/lib/i18n/getDate";
import { LinkIcon } from "@heroicons/react/24/solid";
import { BookText } from "~/locales";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import { LOCALES } from "~/lib/i18n/getLang";
import { getPublicEnv } from "~/lib/env";
import { createSupabaseBuild } from "~/lib/supabase/build";

export const prerender = true;

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const supabase = createSupabaseBuild();
const { BASE_URL: baseUrl, IMG_PREFIX: imgPrefix } = getPublicEnv(Astro.locals);

const booksResult = await supabase
  .from("book")
  .select(`id, title, rate, comment, link, date, cover (id, alt, storage_key)`)
  .order("date", { ascending: false });

interface BookRow {
  id: number;
  title: string;
  rate: number | null;
  comment: string | null;
  link: string | null;
  date: string | null;
  cover: { alt: string | null; storage_key: string } | null;
}

const isRecord = (value: unknown): value is Record<string, unknown> =>
  typeof value === "object" && value !== null;

const books: BookRow[] = (booksResult.data ?? [])
  .map((row): BookRow | null => {
    if (!isRecord(row)) return null;
    const id = row["id"];
    if (typeof id !== "number") return null;
    const cover = row["cover"];
    const normalizedCover =
      isRecord(cover) && typeof cover["storage_key"] === "string"
        ? {
            alt: typeof cover["alt"] === "string" ? (cover["alt"] as string) : null,
            storage_key: cover["storage_key"] as string,
          }
        : null;
    return {
      id,
      title: typeof row["title"] === "string" ? (row["title"] as string) : "",
      rate: typeof row["rate"] === "number" ? (row["rate"] as number) : null,
      comment: typeof row["comment"] === "string" ? (row["comment"] as string) : null,
      link: typeof row["link"] === "string" ? (row["link"] as string) : null,
      date: typeof row["date"] === "string" ? (row["date"] as string) : null,
      cover: normalizedCover,
    };
  })
  .filter((b): b is BookRow => b !== null);

const totalCount = books.length;
const label = getLanguageLabel(BookText, lang!);
const availableLangs = ["zh", "en", "jp"];
const pathWithoutLang = "book";
---

<Layout
  lang={lang!}
  title={`${label.title}(${totalCount})`}
  description={label.description}
  ogTitle={label.title}
  ogDescription={label.description}
  pathWithoutLang={pathWithoutLang}
  availableLangs={availableLangs}
  baseUrl={baseUrl}
>
  <Subnav lang={lang!} active="others" />
  <h1 class="sr-only">Books</h1>
  <div class="w-full max-w-6xl mx-auto p-4 md:py-8 my-8 lg:my-12">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        books.map((book) => (
          <div class="flex gap-4 justify-between items-start lg:my-4">
            {book.cover && (
              <img
                src={`${imgPrefix}/cdn-cgi/image/format=auto,width=240/${book.cover.storage_key}`}
                alt={book.cover.alt ?? ""}
                loading="lazy"
                decoding="async"
                class="h-32 aspect-3/4 object-cover shadow-lg"
              />
            )}
            <div class="w-full space-y-2 lg:space-y-3">
              <h3 class="font-medium text-lg text-zinc-800">{book.title}</h3>
              <RateStars n={book.rate} />
              {book.comment && <p class="text-zinc-700">{book.comment}</p>}
              {book.date && <div class="text-sm text-zinc-500">{getDate(book.date, lang!)}</div>}
              {book.link && (
                <a href={book.link} target="_blank" class="block my-2" rel="noreferrer">
                  <LinkIcon className="w-4 h-4 text-zinc-500 hover:text-violet-700 cursor-pointer" />
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
