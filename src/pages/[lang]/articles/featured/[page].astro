---
import Layout from "~/layouts/Base.astro";
import Subnav from "~/components/Subnav.astro";
import FeaturedArticle from "~/components/FeaturedArticle.astro";
import Pagination from "~/components/Pagination.astro";
import PageViewListRefresher from "~/components/PageViewListRefresher.tsx";
import { normalizeArticles } from "~/lib/articles";
import { HomepageText } from "~/locales";
import getLanguageLabel from "~/lib/i18n/getLanguageLabel";
import { LOCALES } from "~/lib/i18n/getLang";
import { getPublicEnv } from "~/lib/env";
import { createSupabaseBuild } from "~/lib/supabase/build";

export const prerender = true;

export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const sb = createSupabaseBuild();
  const entries = await Promise.all(
    LOCALES.map(async (lang) => {
      const { count } = await sb
        .from("article")
        .select(`id, language!inner (lang)`, { count: "exact", head: true })
        .eq("is_draft", false)
        .eq("is_featured", true)
        .eq("language.lang", lang);
      const totalPages = Math.max(1, Math.ceil((count ?? 0) / PAGE_SIZE));
      return Array.from({ length: totalPages }, (_, i) => ({
        params: { lang, page: String(i + 1) },
      }));
    }),
  );
  return entries.flat();
}

const { lang, page: pageParam } = Astro.params;
const page = Number(pageParam);

const supabase = createSupabaseBuild();
const { BASE_URL: baseUrl, IMG_PREFIX: imgPrefix } = getPublicEnv(Astro.locals);

const [articleRowsResult, articleCountResult] = await Promise.all([
  supabase
    .from("article")
    .select(
      `
      id, title, slug, subtitle, abstract, is_featured, is_premium, topic,
      published_at, page_view,
      category (title, slug),
      cover (alt, storage_key, width, height),
      language!inner (lang),
      comments:comment(count)
      `,
    )
    .eq("language.lang", lang!)
    .limit(12)
    .range((page - 1) * 12, page * 12 - 1)
    .filter("is_draft", "eq", false)
    .filter("is_featured", "eq", true)
    .order("published_at", { ascending: false }),
  supabase
    .from("article")
    .select(`id, language!inner (lang)`, { count: "exact", head: true })
    .filter("is_draft", "eq", false)
    .filter("is_featured", "eq", true)
    .eq("language.lang", lang!),
]);

const articles = normalizeArticles(articleRowsResult.data);
const articleIds = articles.map((a) => a.id);
const env = getPublicEnv(Astro.locals);
const articleCount = articleCountResult.count ?? 0;

const label = getLanguageLabel(HomepageText, lang!);
const availableLangs = ["zh", "en", "jp"];
const path = `/${lang}/articles/featured`;
const ogImageStorage =
  articles[0]?.cover?.storage_key ?? "a2b148a3-5799-4be0-a8d4-907f9355f20f";
const ogImage = `${imgPrefix}/cdn-cgi/image/format=jpeg,width=960/${ogImageStorage}`;
---

<Layout
  lang={lang}
  title={label.featured_article_title}
  description={label.featured_article_description}
  ogTitle={label.featured_article_title}
  ogDescription={label.featured_article_description}
  ogImage={ogImage}
  ogType="article"
  pathWithoutLang="articles/featured"
  availableLangs={availableLangs}
  baseUrl={baseUrl}
  rssHref={`${baseUrl}/${lang}/article/rss.xml`}
>
  <Subnav lang={lang} active="article" />

  {
    articles.length === 0 ? (
      <div class="w-full max-w-8xl mx-auto px-4 my-16 text-center text-zinc-500">
        No articles found
      </div>
    ) : (
      <>
        <h1 class="sr-only">Featured Articles</h1>
        <div class="w-full max-w-8xl mx-auto p-4 md:py-8 mb-8 lg:mb-16 space-y-8 lg:space-y-12">
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {articles.map((article) => (
              <FeaturedArticle article={article} lang={lang} imgPrefix={imgPrefix} />
            ))}
          </div>
          <Pagination count={articleCount} limit={12} page={page} path={path} lang={lang} />
        </div>
      </>
    )
  }

  {articleIds.length > 0 && (
    <PageViewListRefresher
      client:idle
      supabaseUrl={env.SUPABASE_URL}
      supabaseAnonKey={env.SUPABASE_ANON_KEY}
      articleIds={articleIds}
    />
  )}
</Layout>
