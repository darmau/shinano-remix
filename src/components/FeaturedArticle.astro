---
import type { Article } from "~/types/Article";
import type { Image } from "~/types/Image";
import getTime from "~/lib/i18n/getTime";
import ResponsiveImage from "~/components/ResponsiveImage.tsx";
import { ChatBubbleOvalLeftIcon, EyeIcon } from "@heroicons/react/24/outline";

interface Props {
  article: Article;
  lang: string;
  imgPrefix: string;
}

const { article, lang, imgPrefix } = Astro.props;
---

<article class="group">
  <a href={`/${lang}/article/${article.slug}`}>
    {
      article.cover && (
        <ResponsiveImage
          client:visible
          image={article.cover as Image}
          width={480}
          classList="aspect-5/3 sm:aspect-3/1 md:aspect-3/2 w-full rounded-md overflow-hidden mb-4"
          prefix={imgPrefix}
        />
      )
    }
    <div class="flex flex-col gap-3">
      <div class="text-zinc-400 text-sm">
        <span class="text-violet-700 font-medium">{article.category.title}</span>
        &nbsp;·&nbsp;
        <span>{getTime(article.published_at, lang)}</span>
      </div>
      <h3 class="font-medium text-zinc-800 group-hover:text-violet-900 text-xl lg:text-2xl">
        {article.title}
      </h3>
      <h4 class="text-base text-zinc-500 leading-7">{article.subtitle}</h4>
      {
        article.topic && (
          <div class="flex flex-wrap gap-2">
            {article.topic.map((topic) => (
              <span class="inline-flex items-center rounded-md bg-zinc-100 px-2 py-1 text-xs text-zinc-600">
                {topic}
              </span>
            ))}
          </div>
        )
      }
      <div class="flex gap-3 justify-start items-center">
        <div class="flex gap-1 items-center">
          <EyeIcon className="h-4 w-4 inline-block text-zinc-400" />
          <span class="text-zinc-500 text-sm">{article.page_view}</span>
        </div>
        <div class="flex gap-1 items-center">
          <ChatBubbleOvalLeftIcon className="h-4 w-4 inline-block text-zinc-400" />
          <span class="text-zinc-500 text-sm">{article.comments[0].count}</span>
        </div>
      </div>
    </div>
  </a>
</article>
