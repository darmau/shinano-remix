---
import type { Article } from "~/types/Article";
import getTime from "~/lib/i18n/getTime";
import { ChatBubbleOvalLeftIcon, EyeIcon, LockClosedIcon } from "@heroicons/react/24/outline";

interface Props {
  article: Article;
  lang: string;
  showAbstract?: boolean;
}

const { article, lang, showAbstract = false } = Astro.props;
---

<article title={article.abstract ?? ""} class="group">
  <a
    href={`/${lang}/article/${article.slug}`}
    class="flex flex-col gap-2"
  >
    <div class="text-zinc-400 text-sm">
      <span class="text-violet-700 font-medium">{article.category.title}</span>
      &nbsp;·&nbsp;
      <span>{getTime(article.published_at, lang)}</span>
    </div>
    <div class="flex items-center gap-2 text-zinc-800 group-hover:text-violet-900">
      {
        article.is_premium && (
          <LockClosedIcon className="h-5 w-5 text-violet-600 mt-0.5" />
        )
      }
      <h3 class="text-2xl font-medium">{article.title}</h3>
    </div>
    <h4 class="text-base text-zinc-500 leading-7">{article.subtitle}</h4>
    {
      article.topic && (
        <div class="flex flex-wrap gap-2 pt-2">
          {article.topic.map((topic) => (
            <span class="inline-flex items-center rounded-md bg-zinc-100 px-2 py-1 text-xs text-zinc-600">
              {topic}
            </span>
          ))}
        </div>
      )
    }
    {
      showAbstract && article.abstract && (
        <div class="bg-zinc-100 p-2 text-sm text-zinc-700 mt-3 rounded-md md:p-4 leading-6">
          {article.abstract}
        </div>
      )
    }
    <div class="flex gap-3 justify-start items-center mt-2">
      <div class="flex gap-1 items-center">
        <EyeIcon className="h-4 w-4 inline-block text-zinc-400" />
        <span id={`article-${article.id}-page-view`} class="text-zinc-500 text-sm">{article.page_view}</span>
      </div>
      <div class="flex gap-1 items-center">
        <ChatBubbleOvalLeftIcon className="h-4 w-4 inline-block text-zinc-400" />
        <span class="text-zinc-500 text-sm">{article.comments[0].count}</span>
      </div>
    </div>
  </a>
</article>
